# Staging Supabase configuration (local-only)
# Usage:
#   cp .env.staging.example .env.staging.local
#   npm run dev:staging

VITE_SUPABASE_URL="https://your-staging-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-staging-anon-key"
VITE_SUPABASE_PUBLISHABLE_KEY="your-staging-anon-key"
VITE_SUPABASE_FUNCTIONS_URL="https://your-staging-project-ref.supabase.co/functions/v1"
VITE_VAPID_PUBLIC_KEY="your-staging-vapid-public-key"
VITE_ENABLE_ACTIVITY_PUSH_FALLBACK="false"
